# Copy to .env and fill in. The .env file is gitignored; this template is not.
SECRET_KEY=generate-a-random-50-char-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
DATABASE_URL=postgres://USER@localhost:5432/eztrack

CORS_ALLOW_ALL_ORIGINS=True
# In production, set CORS_ALLOW_ALL_ORIGINS=False and list origins explicitly:
# CORS_ALLOWED_ORIGINS=https://your-app-domain.com
