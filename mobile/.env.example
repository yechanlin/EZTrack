# Copy to .env only when you need to override the backend URL.
#
# In local development you normally DON'T need this file at all: the app reads the
# IP of the machine running the Expo dev server and points at port 8000 on the same
# host, so a phone on the same Wi-Fi finds your Mac automatically.
#
# Set this to target a deployed backend instead. The EXPO_PUBLIC_ prefix is what
# makes Expo inline the value into the app bundle at build time.
# EXPO_PUBLIC_API_URL=https://eztrack-api.onrender.com
